# Server
PORT=3000

# MongoDB
# Option A — Local Docker Compose (dùng khi chạy docker compose up)
MONGODB_CONNECTIONSTRING=mongodb://mongodb:27017/xsmn

# Option B — MongoDB Atlas (cloud)
# MONGODB_CONNECTIONSTRING=mongodb+srv://<user>:<password>@cluster.mongodb.net/xsmn

# Redis
# Option A — Local Docker Compose
REDIS_URL=redis://redis:6379

# Option B — Upstash Redis (cloud, có TLS)
# REDIS_URL=rediss://:<password>@<host>.upstash.io:6379
